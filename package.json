{
  "name": "lilazul-lovense-connector",
  "version": "0.1.0",
  "private": true,
  "description": "Private, safety-first Lovense MCP connector for ChatGPT and Railway.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postinstall": "patch-package",
    "start": "node dist/src/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "5.2.1",
    "patch-package": "8.0.1",
    "socket.io-client": "2.5.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.10.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "overrides": {
    "parseuri": "3.0.2"
  }
}
